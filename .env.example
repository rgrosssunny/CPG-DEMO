# Copy this file to ".env" and fill in your Veryfi credentials.
# Find them at: https://app.veryfi.com  ->  Settings -> Keys
#   Client Id   -> VERYFI_CLIENT_ID
#   Username    -> VERYFI_USERNAME
#   API Key     -> VERYFI_API_KEY

VERYFI_CLIENT_ID=your_client_id_here
VERYFI_USERNAME=your_username_here
VERYFI_API_KEY=your_api_key_here

# ---- AWS Textract (camera-capture SDK path) ----------------------------------
# The /aws/* endpoints call Amazon Textract AnalyzeExpense directly on the
# uploaded bytes (no S3 bucket needed for local testing). boto3 picks up
# credentials from the standard chain: environment variables below,
# ~/.aws/credentials, or an attached IAM role.
AWS_REGION=us-east-1
# Optional — only if you don't use ~/.aws/credentials or a role:
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key

# Reject receipts older than this many days (temporal fraud rule). 0 disables.
RECEIPT_MAX_AGE_DAYS=14
# Reject Textract results whose average field confidence is below this (0-100).
TEXTRACT_MIN_CONFIDENCE=50
# Anti-fraud dedup (image hash + vendor/total/date). Off by default so the same
# receipt can be re-scanned during testing; set true to enforce in production.
DEDUP_ENABLED=false
